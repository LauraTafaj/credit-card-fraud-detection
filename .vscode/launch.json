{
    // These let you run the project from VS Code's "Run and Debug" panel (F5)
    // without typing commands. Pick one from the dropdown at the top.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "1. Explore data (EDA)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/explore_data.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "2. Run full pipeline (train + evaluate)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "3. Predict (command line demo)",
            "type": "debugpy",
            "request": "launch",
            "module": "src.predict",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
